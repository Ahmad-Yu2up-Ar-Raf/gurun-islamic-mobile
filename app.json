{
  "expo": {
    "name": " ",
    "slug": " ",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/splash.svg",
    "scheme": "gurun",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo/splash.svg"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/logo.svg",
        "backgroundColor": "#dc2626"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/logo/logo.svg"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-audio",
      "expo-image",
      "expo-splash-screen",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
